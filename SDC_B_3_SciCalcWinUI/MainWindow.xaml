<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="SDC_B_3_SciCalcWinUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:SDC_B_3_SciCalcWinUI"
    Title="SDC_B_3_SciCalcWinUI">

    <Grid x:Name="RootGrid" Padding="12" Background="Transparent"
      SizeChanged="RootGrid_SizeChanged">

        <!-- Outer grid: Display row + Sci row + Button grid, all stretch -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Display -->
            <Border Grid.Row="0" Background="#1E1E1E" CornerRadius="8"
                    Padding="16,12" Margin="0,0,0,8">
                <StackPanel>
                    <TextBlock x:Name="ExpressionText"
                               Text="" FontSize="14"
                               Foreground="#888888"
                               HorizontalAlignment="Right"/>
                    <TextBlock x:Name="DisplayText"
                               Text="0" FontSize="40"
                               Foreground="White"
                               HorizontalAlignment="Right"
                               TextTrimming="CharacterEllipsis"/>
                </StackPanel>
            </Border>

            <!-- Scientific Panel -->
            <Grid x:Name="ScientificPanel" Grid.Row="1" Margin="0,0,0,8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Row="0" Grid.Column="0" Content="sin" Tag="sin" Click="Sci_Click" Style="{StaticResource SciButtonStyle}"/>
                <Button Grid.Row="0" Grid.Column="1" Content="cos" Tag="cos" Click="Sci_Click" Style="{StaticResource SciButtonStyle}"/>
                <Button Grid.Row="0" Grid.Column="2" Content="tan" Tag="tan" Click="Sci_Click" Style="{StaticResource SciButtonStyle}"/>
                <Button Grid.Row="0" Grid.Column="3" Content="log" Tag="log" Click="Sci_Click" Style="{StaticResource SciButtonStyle}"/>
                <Button Grid.Row="0" Grid.Column="4" Content="ln"  Tag="ln"  Click="Sci_Click" Style="{StaticResource SciButtonStyle}"/>
                <Button Grid.Row="1" Grid.Column="0" Content="x²"  Tag="sq"  Click="Sci_Click" Style="{StaticResource SciButtonStyle}"/>
                <Button Grid.Row="1" Grid.Column="1" Content="√"   Tag="sqrt" Click="Sci_Click" Style="{StaticResource SciButtonStyle}"/>
                <Button Grid.Row="1" Grid.Column="2" Content="xʸ"  Tag="pow" Click="Sci_Click" Style="{StaticResource SciButtonStyle}"/>
                <Button Grid.Row="1" Grid.Column="3" Content="π"   Tag="pi"  Click="Sci_Click" Style="{StaticResource SciButtonStyle}"/>
                <Button Grid.Row="1" Grid.Column="4" Content="e"   Tag="e"   Click="Sci_Click" Style="{StaticResource SciButtonStyle}"/>
            </Grid>

            <!-- Standard Buttons — fills remaining height -->
            <Grid Grid.Row="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Row 0: AC, Backspace, (, ) -->
                <Button Grid.Row="0" Grid.Column="0" Content="AC"  Click="Clear_Click"     Style="{StaticResource FuncButtonStyle}"/>
                <Button Grid.Row="0" Grid.Column="1" Content="⌫"   Click="Backspace_Click" Style="{StaticResource FuncButtonStyle}"/>
                <Button Grid.Row="0" Grid.Column="2" Content="("   Click="OpenParen_Click" Style="{StaticResource FuncButtonStyle}"/>
                <Button Grid.Row="0" Grid.Column="3" Content=")"   Click="CloseParen_Click" Style="{StaticResource FuncButtonStyle}"/>

                <!-- Row 1: +/-, %, ^, ÷ -->
                <Button Grid.Row="1" Grid.Column="0" Content="+/-" Click="Sign_Click"       Style="{StaticResource FuncButtonStyle}"/>
                <Button Grid.Row="1" Grid.Column="1" Content="%"   Click="Percent_Click"    Style="{StaticResource FuncButtonStyle}"/>
                <Button Grid.Row="1" Grid.Column="2" Content="^"   Tag="^" Click="Op_Click" Style="{StaticResource FuncButtonStyle}"/>
                <Button Grid.Row="1" Grid.Column="3" Content="÷"   Tag="/" Click="Op_Click" Style="{StaticResource OpButtonStyle}"/>

                <!-- Row 2: 7 8 9 × -->
                <Button Grid.Row="2" Grid.Column="0" Content="7" Tag="7" Click="Num_Click" Style="{StaticResource NumButtonStyle}"/>
                <Button Grid.Row="2" Grid.Column="1" Content="8" Tag="8" Click="Num_Click" Style="{StaticResource NumButtonStyle}"/>
                <Button Grid.Row="2" Grid.Column="2" Content="9" Tag="9" Click="Num_Click" Style="{StaticResource NumButtonStyle}"/>
                <Button Grid.Row="2" Grid.Column="3" Content="×"  Tag="*" Click="Op_Click" Style="{StaticResource OpButtonStyle}"/>

                <!-- Row 3: 4 5 6 - -->
                <Button Grid.Row="3" Grid.Column="0" Content="4" Tag="4" Click="Num_Click" Style="{StaticResource NumButtonStyle}"/>
                <Button Grid.Row="3" Grid.Column="1" Content="5" Tag="5" Click="Num_Click" Style="{StaticResource NumButtonStyle}"/>
                <Button Grid.Row="3" Grid.Column="2" Content="6" Tag="6" Click="Num_Click" Style="{StaticResource NumButtonStyle}"/>
                <Button Grid.Row="3" Grid.Column="3" Content="-"  Tag="-" Click="Op_Click" Style="{StaticResource OpButtonStyle}"/>

                <!-- Row 4: 1 2 3 + -->
                <Button Grid.Row="4" Grid.Column="0" Content="1" Tag="1" Click="Num_Click" Style="{StaticResource NumButtonStyle}"/>
                <Button Grid.Row="4" Grid.Column="1" Content="2" Tag="2" Click="Num_Click" Style="{StaticResource NumButtonStyle}"/>
                <Button Grid.Row="4" Grid.Column="2" Content="3" Tag="3" Click="Num_Click" Style="{StaticResource NumButtonStyle}"/>
                <Button Grid.Row="4" Grid.Column="3" Content="+"  Tag="+" Click="Op_Click" Style="{StaticResource OpButtonStyle}"/>

                <!-- Row 5: 0 (wide), ., = -->
                <Button Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2" Content="0" Tag="0" Click="Num_Click" Style="{StaticResource NumButtonStyle}"/>
                <Button Grid.Row="5" Grid.Column="2" Content="."  Click="Dot_Click"          Style="{StaticResource NumButtonStyle}"/>
                <Button Grid.Row="5" Grid.Column="3" Content="="  Click="Equals_Click"       Style="{StaticResource EqualButtonStyle}"/>

            </Grid>

        </Grid>
    </Grid>
</Window>