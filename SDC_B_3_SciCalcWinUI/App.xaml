<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="SDC_B_3_SciCalcWinUI.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:SDC_B_3_SciCalcWinUI">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Base Button Style -->
            <Style x:Key="BaseButtonStyle" TargetType="Button">
                <Setter Property="FontSize" Value="20"/>
                <Setter Property="CornerRadius" Value="6"/>
                <Setter Property="HorizontalAlignment" Value="Stretch"/>
                <Setter Property="VerticalAlignment" Value="Stretch"/>
                <Setter Property="Margin" Value="3"/>
            </Style>

            <Style x:Key="NumButtonStyle" TargetType="Button"
                   BasedOn="{StaticResource BaseButtonStyle}">
                <Setter Property="Background" Value="#333333"/>
                <Setter Property="Foreground" Value="White"/>
            </Style>

            <Style x:Key="OpButtonStyle" TargetType="Button"
                   BasedOn="{StaticResource BaseButtonStyle}">
                <Setter Property="Background" Value="#FF9500"/>
                <Setter Property="Foreground" Value="White"/>
            </Style>

            <Style x:Key="FuncButtonStyle" TargetType="Button"
                   BasedOn="{StaticResource BaseButtonStyle}">
                <Setter Property="Background" Value="#505050"/>
                <Setter Property="Foreground" Value="White"/>
            </Style>

            <Style x:Key="SciButtonStyle" TargetType="Button"
                   BasedOn="{StaticResource BaseButtonStyle}">
                <Setter Property="Background" Value="#1C3A5E"/>
                <Setter Property="Foreground" Value="#4FC3F7"/>
                <Setter Property="Height" Value="40"/>
                <Setter Property="FontSize" Value="14"/>
            </Style>

            <Style x:Key="EqualButtonStyle" TargetType="Button"
                   BasedOn="{StaticResource BaseButtonStyle}">
                <Setter Property="Background" Value="#FF9500"/>
                <Setter Property="Foreground" Value="White"/>
            </Style>

        </ResourceDictionary>
    </Application.Resources>
</Application>